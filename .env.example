# .env.example -- All environment variables for ASTN
#
# Copy to .env.local and fill in values:
#   cp .env.example .env.local
#
# Variables prefixed with PUBLIC_ are exposed to the client bundle.
# Variables without PUBLIC_ prefix are server-side only.

# === SvelteKit public env ===

PUBLIC_CONVEX_URL=             # Convex deployment URL (from `npx convex dev`)
PUBLIC_CONVEX_SITE_URL=        # Convex site URL for HTTP endpoints / uploads
PUBLIC_CLERK_PUBLISHABLE_KEY=  # Clerk publishable key (pk_test_ for dev, pk_live_ for production)
PUBLIC_POSTHOG_KEY=            # PostHog project key
PUBLIC_POSTHOG_HOST=           # PostHog host, e.g. https://us.i.posthog.com
PUBLIC_SENTRY_DSN=             # Sentry DSN for client/server runtime error reporting

# === Server-only auth bridge ===

CLERK_SECRET_KEY=              # Clerk backend secret key
CONVEX_PRIVATE_BRIDGE_KEY=     # Convex private bridge key for trusted server calls
CLERK_JWT_ISSUER_DOMAIN=       # Clerk issuer URL used by Convex auth.config.ts

# === Convex / backend env ===

ANTHROPIC_API_KEY=             # Anthropic API key for LLM features
RESEND_API_KEY=                # Resend API key for transactional emails
EIGHTY_K_ALGOLIA_APP_ID=       # 80,000 Hours Algolia app ID
EIGHTY_K_ALGOLIA_API_KEY=      # 80,000 Hours Algolia search key
AIRTABLE_TOKEN=                # Airtable Personal Access Token
AIRTABLE_BASE_ID=              # Airtable base ID for aisafety.com jobs
AIRTABLE_TABLE_NAME=           # Airtable table name (default: "Jobs")
AUTH_GITHUB_ID=                # GitHub OAuth app client ID
AUTH_GITHUB_SECRET=            # GitHub OAuth app client secret
AUTH_GOOGLE_ID=                # Google OAuth client ID
AUTH_GOOGLE_SECRET=            # Google OAuth client secret

# === Tauri-specific (optional, deferred in the Svelte migration) ===

PUBLIC_GOOGLE_CLIENT_ID=         # Google client ID for Tauri OAuth flow
PUBLIC_GITHUB_CLIENT_ID_MOBILE=  # GitHub client ID for Tauri OAuth flow
AUTH_GITHUB_ID_MOBILE=           # GitHub OAuth for mobile/Tauri
AUTH_GITHUB_SECRET_MOBILE=       # GitHub OAuth secret for mobile/Tauri
AUTH_REDIRECT_URI_WEB=           # Web redirect URI for Tauri auth flow
