    "class-variance-authority": "^0.7.1",
    "clsx": "^2.1.1",
    "cmdk": "^1.1.1",
    "convex": "^1.32.0",
    "date-fns": "^4.1.0",
    "date-fns-tz": "^3.2.0",
    "dompurify": "^3.3.1",
    "exa-js": "^2.4.0",
    "leaflet": "^1.9.4",
    "lucide-react": "^0.562.0",
    "marked": "^17.0.3",
    "nitro": "^3.0.1-alpha.1",
    "posthog-node": "^5.26.0",
    "radix-ui": "^1.4.3",
    "react": "^19.2.1",
    "react-day-picker": "^9.13.0",
    "react-dom": "^19.2.1",
    "react-dropzone": "^14.3.8",
    "react-resizable-panels": "^4",
