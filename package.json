{
  "name": "astn",
  "private": true,
  "sideEffects": false,
  "type": "module",
  "scripts": {
    "agent": "bun agent/cli.ts",
    "dev": "bunx convex dev --once && concurrently -r bun:dev:web bun:dev:convex",
    "dev:web": "NODE_OPTIONS='--import ./instrument.server.mjs' vite dev",
    "dev:ts": "tsc -b -w",
    "dev:convex": "bunx convex dev",
    "build": "vite build && cp instrument.server.mjs .output/server",
    "start": "node --import ./.output/server/instrument.server.mjs .output/server/index.mjs",
    "format": "prettier --write .",
    "lint": "eslint . --report-unused-disable-directives --max-warnings 0",
    "typecheck": "tsc --noEmit",
    "build:tauri": "vite build --config vite.config.tauri.ts && cp dist/client/_shell.html dist/client/index.html",
    "dev:tauri:web": "vite dev --config vite.config.tauri.ts --port 3000",
    "dev:tauri": "tauri dev --config src-tauri/tauri.conf.json",
    "tauri:ios:dev": "tauri ios dev",
    "tauri:android:dev": "tauri android dev",
    "tauri:ios:build": "tauri ios build",
    "tauri:android:build": "tauri android build",
    "prepare": "husky"
  },
  "dependencies": {
    "@ai-sdk/anthropic": "^3.0.46",
    "@anthropic-ai/sdk": "^0.71.2",
    "@clerk/clerk-react": "^5.61.1",
    "@convex-dev/agent": "0.6.0-alpha.1",
    "@convex-dev/persistent-text-streaming": "^0.3.0",
    "@convex-dev/rate-limiter": "^0.3.2",
    "@convex-dev/react-query": "^0.0.0-alpha.11",
    "@convex-dev/resend": "^0.2.3",
    "@fontsource-variable/lora": "^5.2.8",
    "@fontsource-variable/plus-jakarta-sans": "^5.2.8",
    "@fontsource-variable/space-grotesk": "^5.2.10",
    "@google/genai": "^1.42.0",
    "@ikhrustalev/convex-debouncer": "^0.1.0",
    "@posthog/react": "^1.8.1",
    "@radix-ui/react-alert-dialog": "^1.1.15",
    "@radix-ui/react-avatar": "^1.1.11",
    "@radix-ui/react-checkbox": "^1.3.3",
    "@radix-ui/react-dialog": "^1.1.15",
    "@radix-ui/react-dropdown-menu": "^2.1.16",
    "@radix-ui/react-label": "^2.1.8",
    "@radix-ui/react-popover": "^1.1.15",
    "@radix-ui/react-select": "^2.2.6",
    "@radix-ui/react-separator": "^1.1.8",
    "@radix-ui/react-slot": "^1.2.4",
    "@radix-ui/react-switch": "^1.2.6",
    "@radix-ui/react-tabs": "^1.1.13",
    "@radix-ui/react-tooltip": "^1.2.8",
