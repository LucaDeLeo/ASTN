{
  "$schema": "../node_modules/@tauri-apps/cli/config.schema.json",
  "productName": "ASTN",
  "version": "0.1.0",
  "identifier": "ai.astn.mobile",
  "build": {
    "frontendDist": "../dist/client",
    "devUrl": "http://localhost:3000",
    "beforeDevCommand": "",
    "beforeBuildCommand": "bun run build:tauri"
  },
  "app": {
    "windows": [
      {
        "title": "AI Safety Talent Network",
        "width": 390,
        "height": 844,
        "resizable": true,
        "fullscreen": false
      }
    ],
    "security": {
      "csp": null
    }
  },
  "bundle": {
    "active": true,
    "targets": "all",
    "icon": [
      "icons/32x32.png",
      "icons/128x128.png",
      "icons/128x128@2x.png",
      "icons/icon.icns",
      "icons/icon.ico"
    ],
    "iOS": {
      "minimumSystemVersion": "16.0"
    }
  },
  "plugins": {
    "deep-link": {
      "mobile": [
        { "host": "safetytalent.org", "pathPrefix": ["/"] },
        { "host": "*.safetytalent.org", "pathPrefix": ["/"] }
      ],
      "desktop": {
        "schemes": ["astn"]
      }
    }
  }
}
