{
  "extends": "./.svelte-kit/tsconfig.json",
  "include": [
    ".svelte-kit/ambient.d.ts",
    ".svelte-kit/non-ambient.d.ts",
    ".svelte-kit/types/**/*.d.ts",
    "src/app.d.ts",
    "src/**/*.svelte",
    "src/**/*.svelte.ts",
    "src/**/*.ts",
    "src/hooks.client.ts",
    "src/hooks.server.ts",
    "eslint.config.mjs",
    "svelte.config.js",
    "vite.config.ts"
  ],
  "exclude": [
    "node_modules",
    "src-tauri",
    "agent",
    "convex",
    "shared",
    "public",
    "src/**/*.tsx",
    "src/**/*.jsx"
  ],
  "compilerOptions": {
    "allowJs": true,
    "checkJs": false,
    "esModuleInterop": true,
    "forceConsistentCasingInFileNames": true,
    "jsx": "react-jsx",
    "moduleResolution": "bundler",
    "noEmit": true,
    "resolveJsonModule": true,
    "rewriteRelativeImportExtensions": true,
    "skipLibCheck": true,
    "sourceMap": true,
    "strict": true
  }
}
